# PostgreSQL connection string
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/construction_inspector

# JWT signing secret — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# OpenAI API key — used for Whisper audio transcription
OPENAI_API_KEY=sk-...

# Firebase Cloud Messaging server key (legacy HTTP API)
FCM_SERVER_KEY=AAAA...

# HTTP port (optional, defaults to 3000)
PORT=3000
